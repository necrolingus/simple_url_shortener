{{#if rateLimitError}}
<div class="error-message rate-limit-error">{{rateLimitError}}</div>
{{/if}}

<h1>Shorten URL</h1>
<form id="shortenForm">
    <input type="text" id="longUrl" name="longUrl" placeholder="Paste your long URL here..." required>

    <input type="number" id="expiryDays" name="expiryDays" placeholder="Expiry (days)" min="1">

    <input type="text" id="customShortUrl" name="customShortUrl" placeholder="Custom Alias (optional)">

    <button type="submit">Shorten</button>
    <div id="shortenError" class="error-message"></div>
</form>

<div class="result-container" id="resultContainer">
    <div class="short-url" id="shortUrlResult"></div>
    <button onclick="copyToClipboard()">Copy</button>
</div>

{{#if urls.length}}
<h2 class="table-heading">Your URLs</h2>
<div class="table-wrapper">
    <table class="url-table" id="urlTable">
        <thead>
            <tr>
                <th>Short URL</th>
                <th>Long URL</th>
                <th>Created</th>
                <th>Expires</th>
                <th>Clicks</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {{#each urls}}
            <tr id="row-{{this.shortURL}}" class="{{#if this.isExpired}}expired-row{{/if}}">
                <td><a href="{{this.fullShortURL}}" target="_blank" class="table-link">{{this.shortURL}}</a></td>
                <td class="long-url-cell" title="{{this.longURL}}">{{this.longURL}}</td>
                <td class="date-cell">{{this.createdDate}}</td>
                <td class="date-cell">{{this.expiryDate}}</td>
                <td class="click-cell">{{this.clickCount}}</td>
                <td><button class="delete-btn" onclick="deleteUrl('{{this.shortURL}}')">✕</button></td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>
{{/if}}